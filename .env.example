# EXPANSION_MODEL=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Storage
DB_PATH=./data/bot.db

# Behavior
LOG_LEVEL=info
MEDIA_GROUP_FLUSH_MS=2000
